# Silver / SLV Trading Terminal local live app

# Run target
HOST=127.0.0.1
PORT=8788

# Official API session auth. This is what Connect Tastytrade uses.
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_SESSION_TOKEN=

# Experimental OAuth client fields. The dashboard keeps this as a test/fallback path.
TASTYTRADE_CLIENT_ID=
TASTYTRADE_CLIENT_SECRET=
TASTYTRADE_REDIRECT_URI=http://127.0.0.1:8788/auth/tastytrade/callback
TASTYTRADE_REFRESH_TOKEN=

# Override only if tastytrade docs/client settings give different OAuth endpoints.
TASTYTRADE_AUTH_URL=https://my.tastytrade.com/app.html#/oauth/authorize
TASTYTRADE_TOKEN_URL=https://api.tastyworks.com/oauth/token
TASTYTRADE_OAUTH_SCOPE=read trade openid
TASTYTRADE_OAUTH_USE_PKCE=FALSE

# API host override if tastytrade changes hosts.
TASTYTRADE_API_BASE_URL=https://api.tastyworks.com

TASTYTRADE_IGNORE_CLIENT_SECRET=FALSE

TASTYTRADE_USER_AGENT=slv-terminal/1.0

# Strategy silver is MetalPriceAPI-only. Do not source silver from Tastytrade/DXLink.
METALPRICE_API_KEY=
METALPRICE_API_BASE_URL=https://api.metalpriceapi.com/v1
METALPRICE_API_TIMEOUT_MS=5000
EXPECTED_SILVER_MIN=45
EXPECTED_SILVER_MAX=75
SILVER_SPOT_REFRESH_SECONDS=15

# Option chain refresh interval.
OPTION_CHAIN_REFRESH_SECONDS=300
